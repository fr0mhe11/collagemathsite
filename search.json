---
layout: none
---
[
  {% for page in site.pages %}
    {% if page.title %}
    {
      "title"    : "{{ page.title | escape }}",
      "category" : "{{ page.dir | replace: '/', '' }}",
      "url"      : "{{ site.baseurl }}{{ page.url }}"
    } {% unless forloop.last %},{% endunless %}
    {% endif %}
  {% endfor %}
]
