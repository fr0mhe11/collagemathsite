---
layout: none
---
[
  {% assign pages_with_title = site.pages | where_exp: "item", "item.title != nil" %}
  {% for page in pages_with_title %}
    {
      "title"    : "{{ page.title | escape }}",
      "category" : "{{ page.dir | replace: '/', '' }}",
      "url"      : "{{ site.baseurl }}{{ page.url }}"
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
